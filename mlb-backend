@app.get("/api/mlb/slates/{slate_id}/players")
def get_players(
    slate_id: str,
    scored: bool = Query(default=True),
    include_excluded: bool = Query(default=True),
) -> List[Dict[str, Any]]:
    slate = SLATES.get(slate_id)
    if slate is None:
        raise HTTPException(status_code=404, detail="Slate not found.")

    if scored and slate.scored_df is None:
        slate.scored_df, _ = score_slate(slate.raw_df)

    df = slate.scored_df if scored and slate.scored_df is not None else slate.raw_df
    out = df.copy()
    if not include_excluded:
        out = out[~out["exclude"]]
    return out.fillna("").to_dict(orient="records")


@app.post("/api/mlb/slates/{slate_id}/score")
def score_route(slate_id: str, payload: ScoreRequest) -> Dict[str, Any]:
    slate = SLATES.get(slate_id)
    if slate is None:
        raise HTTPException(status_code=404, detail="Slate not found.")

    scored, stacks = score_slate(slate.raw_df)
    if payload.persist:
        slate.scored_df = scored

    top_pitchers = (
        scored[scored["is_pitcher"]]
        .sort_values(by=["BuildScore_single_entry", "projection"], ascending=[False, False])
        .head(10)[["player_id", "name", "team", "salary", "projection", "PitcherCeilingScore", "PitcherSafetyScore"]]
        .fillna("")
        .to_dict(orient="records")
    )
    top_hitters = (
        scored[~scored["is_pitcher"]]
        .sort_values(by=["BuildScore_single_entry", "projection"], ascending=[False, False])
        .head(15)[["player_id", "name", "team", "salary", "projection", "HitterCeilingScore", "LeverageScore", "HitterStackScore"]]
        .fillna("")
        .to_dict(orient="records")
    )

    return {
        "slate_id": slate_id,
        "player_count": len(scored),
        "stack_count": len(stacks),
        "top_pitchers": top_pitchers,
        "top_hitters": top_hitters,
        "top_stacks": stacks.head(10).fillna("").to_dict(orient="records"),
    }


