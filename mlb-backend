    normalized["salary"] = normalized["salary"].astype(int)
    normalized["batting_order"] = normalized["batting_order"].astype(int)
    normalized["team"] = normalized["team"].fillna("").astype(str).str.upper()
    normalized["opponent"] = normalized["opponent"].fillna("").astype(str).str.upper()

    normalized["player_id"] = normalized["player_id"].astype(str).replace({"": None})
    normalized["player_id"] = normalized["player_id"].fillna(normalized.index.map(lambda idx: f"row_{idx}"))
    normalized["name"] = normalized["name"].fillna("Unknown")

    if (normalized["ceiling_projection"] <= 0).all():
        normalized["ceiling_projection"] = normalized["projection"] * 1.45
    if (normalized["floor_projection"] <= 0).all():
        normalized["floor_projection"] = normalized["projection"] * 0.55
    if (normalized["player_volatility"] <= 0).all():
        normalized["player_volatility"] = (normalized["ceiling_projection"] - normalized["projection"]).clip(lower=1.0)
    if (normalized["ownership"] <= 0).all():
        normalized["ownership"] = 0.0
    if (normalized["park_factor"] <= 0).all():
        normalized["park_factor"] = 1.0
    if (normalized["weather_factor"] <= 0).all():
        normalized["weather_factor"] = 1.0

    return normalized



def _slot_eligible(site: str, slot: str, positions: List[str]) -> bool:
    positions_set = set(positions)
    if slot == "UTIL":
        return "P" not in positions_set
    if slot == "C1B":
        return bool({"C", "1B"}.intersection(positions_set))
    return slot in positions_set



def _build_available_slots(site: str) -> List[str]:
    return list(SITE_RULES[site]["slots"])



def _sorted_hitter_pool(df: pd.DataFrame, column: str) -> pd.DataFrame:
    hitters = df[~df["is_pitcher"] & ~df["exclude"]].copy()
    return hitters.sort_values(by=[column, "projection", "salary"], ascending=[False, False, True])



def _sorted_pitcher_pool(df: pd.DataFrame, column: str) -> pd.DataFrame:
    pitchers = df[df["is_pitcher"] & ~df["exclude"]].copy()
    return pitchers.sort_values(by=[column, "projection", "salary"], ascending=[False, False, True])



def _apply_manual_overrides(df: pd.DataFrame, locked_ids: Set[str], excluded_ids: Set[str]) -> pd.DataFrame:
    out = df.copy()
    if locked_ids:
        out.loc[out["player_id"].isin(locked_ids), "lock"] = True
    if excluded_ids:
        out.loc[out["player_id"].isin(excluded_ids), "exclude"] = True
    return out


