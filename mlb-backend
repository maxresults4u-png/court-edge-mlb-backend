@app.post("/api/mlb/upload-csv", response_model=UploadResponse)
async def upload_csv(file: UploadFile = File(...)) -> UploadResponse:
    filename = file.filename or "upload.csv"
    if not filename.lower().endswith(".csv"):
        raise HTTPException(status_code=400, detail="Please upload a CSV file.")

    content = await file.read()
    try:
        raw_df = pd.read_csv(io.BytesIO(content))
    except Exception as exc:  # pragma: no cover
        raise HTTPException(status_code=400, detail=f"Could not read CSV: {exc}") from exc

    if raw_df.empty:
        raise HTTPException(status_code=400, detail="CSV file is empty.")

    site = _infer_site(list(raw_df.columns))
    normalized = _normalize_columns(site, raw_df)
    slate_id = str(uuid.uuid4())
    salary_cap = SITE_RULES[site]["salary_cap"]

    SLATES[slate_id] = SlateStore(
        slate_id=slate_id,
        site=site,
        salary_cap=salary_cap,
        raw_df=normalized,
        lock_time=None,
    )

    return UploadResponse(
        slate_id=slate_id,
        site=site,
        salary_cap=salary_cap,
        player_count=len(normalized),
        team_count=int(normalized["team"].nunique()),
        uploaded_filename=filename,
    )


