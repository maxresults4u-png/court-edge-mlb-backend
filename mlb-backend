    normalized["bullpen_bb_rate"] = _coalesce(df, ["BullpenBBRate", "bullpen_bb_rate"], default=0)
    normalized["bullpen_k_rate"] = _coalesce(df, ["BullpenKRate", "bullpen_k_rate"], default=0)
    normalized["pitcher_swstr"] = _coalesce(df, ["PitcherSwStr", "pitcher_swstr"], default=0)
