def _clean_str(value: Any) -> str:
    if value is None:
        return ""
    return str(value).strip()



def _to_float(value: Any, default: float = 0.0) -> float:
    if value is None or (isinstance(value, float) and math.isnan(value)):
        return default
    if isinstance(value, str):
        cleaned = value.replace("%", "").replace("$", "").replace(",", "").strip()
        if cleaned == "":
            return default
        try:
            return float(cleaned)
        except ValueError:
            return default
    try:
        return float(value)
    except (TypeError, ValueError):
        return default



def _to_int(value: Any, default: int = 0) -> int:
    return int(round(_to_float(value, default=default)))



def _infer_site(columns: List[str]) -> str:
    lowered = {c.lower() for c in columns}
    if {"game info", "nickname", "position"}.issubset(lowered):
        return "fanduel"
    if {"name", "roster position", "salary", "teamabbr"}.issubset(lowered):
        return "draftkings"
    # Default safely to DraftKings because its roster rules are stricter.
    return "draftkings"



def _safe_series(df: pd.DataFrame, column: str, default: float = 0.0) -> pd.Series:
    if column not in df.columns:
        return pd.Series([default] * len(df), index=df.index, dtype=float)
    return pd.to_numeric(df[column], errors="coerce").fillna(default)



def _normalize_0_100(series: pd.Series, inverse: bool = False) -> pd.Series:
    values = pd.to_numeric(series, errors="coerce").fillna(series.mean() if len(series) else 0.0)
    std = values.std(ddof=0)
    if std == 0 or math.isnan(std):
        z = pd.Series([0.0] * len(values), index=values.index)
    else:
        z = (values - values.mean()) / std
    z = z.clip(-2, 2)
    score = 50 + (25 * z)
    if inverse:
        score = 100 - score
    return score.clip(0, 100)



def _coalesce(df: pd.DataFrame, candidates: List[str], default: Any = None) -> pd.Series:
    for candidate in candidates:
        if candidate in df.columns:
            return df[candidate]
    return pd.Series([default] * len(df), index=df.index)



def _parse_positions(site: str, value: Any) -> List[str]:
    text = _clean_str(value).upper()
    if not text:
        return []
    for separator in ["/", ",", "|"]:
        if separator in text:
            return [p.strip() for p in text.split(separator) if p.strip()]

    if site == "draftkings" and text == "C/1B":
        return ["C", "1B"]
    if site == "fanduel" and text in {"C/1B", "1B/C"}:
        return ["C", "1B"]
    return [text]



