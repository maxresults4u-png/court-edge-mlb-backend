@app.post("/api/mlb/slates/{slate_id}/overrides")
def apply_overrides(slate_id: str, payload: OverridesRequest) -> Dict[str, Any]:
    slate = SLATES.get(slate_id)
    if slate is None:
        raise HTTPException(status_code=404, detail="Slate not found.")

    df = slate.scored_df.copy() if slate.scored_df is not None else slate.raw_df.copy()
    updated_ids: List[str] = []

    for override in payload.overrides:
        mask = df["player_id"].astype(str) == str(override.player_id)
        if not mask.any():
            continue
        if override.lock is not None:
            df.loc[mask, "lock"] = override.lock
        if override.exclude is not None:
            df.loc[mask, "exclude"] = override.exclude
        if override.min_exposure is not None:
            df.loc[mask, "min_exposure"] = override.min_exposure
        if override.max_exposure is not None:
            df.loc[mask, "max_exposure"] = override.max_exposure
        updated_ids.append(str(override.player_id))

    slate.raw_df = df
    slate.scored_df = None
    return {"updated_player_ids": updated_ids, "updated_count": len(updated_ids)}


@app.post("/api/mlb/slates/{slate_id}/optimize", response_model=List[BuiltLineup])
def optimize_slate(slate_id: str, rules: BuildRules) -> List[BuiltLineup]:
    slate = SLATES.get(slate_id)
    if slate is None:
        raise HTTPException(status_code=404, detail="Slate not found.")

    if slate.scored_df is None:
        slate.scored_df, _ = score_slate(slate.raw_df)
    scored = slate.scored_df.copy()
    stacks = build_team_stack_scores(scored)
    lineups = build_lineups(scored, stacks, rules, slate.site)

    if not lineups:
        raise HTTPException(
            status_code=422,
            detail="Could not build any valid lineups with the current rules. Loosen stack size, min salary, or exposure constraints.",
        )

    return lineups


@app.post("/api/mlb/slates/{slate_id}/export")
def export_lineups_csv(slate_id: str, rules: BuildRules) -> StreamingResponse:
    slate = SLATES.get(slate_id)
    if slate is None:
        raise HTTPException(status_code=404, detail="Slate not found.")

    if slate.scored_df is None:
        slate.scored_df, _ = score_slate(slate.raw_df)
    scored = slate.scored_df.copy()
    stacks = build_team_stack_scores(scored)
    lineups = build_lineups(scored, stacks, rules, slate.site)

    if not lineups:
        raise HTTPException(
            status_code=422,
            detail="Could not export lineups because no valid lineups were built.",
        )

    export_df = _lineups_to_dataframe(slate.site, lineups)
    csv_bytes = export_df.to_csv(index=False).encode("utf-8")
    filename = f"court_edge_mlb_{slate.site}_{slate_id[:8]}.csv"
    return StreamingResponse(
        io.BytesIO(csv_bytes),
        media_type="text/csv",
        headers={"Content-Disposition": f"attachment; filename={filename}"},
    )


