def _score_hitters(df: pd.DataFrame) -> pd.DataFrame:
    hitters = df[~df["is_pitcher"]].copy()
    if hitters.empty:
        return hitters

    hitters["ProjectionScore"] = _normalize_0_100(hitters["projection"])
    hitters["OrderScore"] = hitters["batting_order"].map(ORDER_SCORES).fillna(60.0)
    split_edge = hitters["hitter_woba_split"] - hitters["pitcher_allowed_woba_split"]
    split_power_edge = hitters["hitter_iso_split"] - hitters["pitcher_allowed_iso_split"]
    hitters["SplitScore"] = (
        0.65 * _normalize_0_100(split_edge) + 0.35 * _normalize_0_100(split_power_edge)
    ).clip(0, 100)
    hitters["TeamRunScore"] = _normalize_0_100(hitters["team_implied_runs"])
    hitters["ParkScore"] = _normalize_0_100(hitters["park_factor"])
    hitters["WeatherScore"] = _normalize_0_100(hitters["weather_factor"])

    hitters["PitcherWeaknessScore"] = (
        0.30 * _normalize_0_100(hitters["pitcher_xfip"])
        + 0.20 * _normalize_0_100(hitters["pitcher_hr9"])
        + 0.15 * _normalize_0_100(hitters["pitcher_bb_rate"])
        + 0.20 * _normalize_0_100(hitters["pitcher_hard_hit_allowed"])
        + 0.15 * _normalize_0_100(hitters["pitcher_k_rate"], inverse=True)
    ).clip(0, 100)

    hitters["BullpenWeaknessScore"] = (
        0.40 * _normalize_0_100(hitters["bullpen_xfip"])
        + 0.25 * _normalize_0_100(hitters["bullpen_hr9"])
        + 0.20 * _normalize_0_100(hitters["bullpen_bb_rate"])
        + 0.15 * _normalize_0_100(hitters["bullpen_k_rate"], inverse=True)
    ).clip(0, 100)

    hitters["HRUpsideScore"] = (
        0.45 * _normalize_0_100(hitters["hitter_iso_split"])
        + 0.20 * _normalize_0_100(hitters["barrel_rate"])
        + 0.15 * _normalize_0_100(hitters["fly_ball_rate"])
        + 0.20 * _normalize_0_100(hitters["pitcher_hr9"])
    ).clip(0, 100)

    hitters["SBScore"] = (
        0.50 * _normalize_0_100(hitters["sb_rate"])
        + 0.20 * _normalize_0_100(hitters["opposing_pitcher_sb_allowed"])
        + 0.15 * _normalize_0_100(hitters["catcher_sb_allowed"])
        + 0.15 * _normalize_0_100(hitters["on_base_skill"])
    ).clip(0, 100)

    hitters["HitterMedianScore"] = (
        0.34 * hitters["ProjectionScore"]
        + 0.14 * hitters["OrderScore"]
        + 0.14 * hitters["SplitScore"]
        + 0.14 * hitters["TeamRunScore"]
        + 0.08 * hitters["ParkScore"]
        + 0.10 * hitters["PitcherWeaknessScore"]
        + 0.06 * hitters["BullpenWeaknessScore"]
    ).clip(0, 100)

    hitters["HitterCeilingScore"] = (
        0.22 * hitters["ProjectionScore"]
        + 0.10 * hitters["OrderScore"]
        + 0.12 * hitters["SplitScore"]
        + 0.10 * hitters["TeamRunScore"]
        + 0.08 * hitters["ParkScore"]
        + 0.14 * hitters["PitcherWeaknessScore"]
        + 0.08 * hitters["BullpenWeaknessScore"]
        + 0.10 * hitters["HRUpsideScore"]
        + 0.06 * hitters["SBScore"]
    ).clip(0, 100)

    points_per_dollar = hitters["projection"] / hitters["salary"].replace(0, pd.NA)
    hitters["ValueScore"] = (
        0.70 * _normalize_0_100(points_per_dollar.fillna(0))
        + 0.30 * hitters["HitterMedianScore"]
    ).clip(0, 100)

    hitters["LeverageScore"] = (
        0.65 * _normalize_0_100(hitters["ceiling_projection"])
        - 0.35 * _normalize_0_100(hitters["ownership"])
    ).clip(0, 100)

    correlation_boost = hitters["batting_order"].map({1: 8, 2: 8, 3: 8, 4: 8, 5: 5, 6: 5, 7: 2, 8: 2, 9: 2}).fillna(2)
    hitters["HitterStackScore"] = (
        0.20 * hitters["HitterMedianScore"]
        + 0.20 * hitters["HitterCeilingScore"]
        + 0.20 * hitters["TeamRunScore"]
        + 0.15 * hitters["OrderScore"]
        + 0.10 * hitters["PitcherWeaknessScore"]
        + 0.10 * hitters["BullpenWeaknessScore"]
        + 0.05 * correlation_boost
    ).clip(0, 100)

    hitters["OneOffScore"] = (
        0.28 * hitters["HitterMedianScore"]
        + 0.32 * hitters["HitterCeilingScore"]
        + 0.20 * hitters["HRUpsideScore"]
        + 0.10 * hitters["SBScore"]
        + 0.10 * hitters["LeverageScore"]
    ).clip(0, 100)

    hitters["BuildScore_cash"] = (0.70 * hitters["HitterMedianScore"] + 0.30 * hitters["ValueScore"]).clip(0, 100)
    hitters["BuildScore_single_entry"] = (
        0.30 * hitters["HitterMedianScore"]
        + 0.35 * hitters["HitterCeilingScore"]
        + 0.20 * hitters["HitterStackScore"]
        + 0.15 * hitters["LeverageScore"]
    ).clip(0, 100)
    hitters["BuildScore_mme"] = (
        0.20 * hitters["HitterMedianScore"]
        + 0.35 * hitters["HitterCeilingScore"]
        + 0.25 * hitters["HitterStackScore"]
        + 0.20 * hitters["LeverageScore"]
    ).clip(0, 100)

    return hitters



def _score_pitchers(df: pd.DataFrame) -> pd.DataFrame:
    pitchers = df[df["is_pitcher"]].copy()
    if pitchers.empty:
        return pitchers

    pitchers["ProjectionScore"] = _normalize_0_100(pitchers["projection"])
    pitchers["KUpsideScore"] = (
        0.45 * _normalize_0_100(pitchers["pitcher_k_rate"])
        + 0.20 * _normalize_0_100(pitchers["pitcher_swstr"])
        + 0.15 * _normalize_0_100(pitchers["pitcher_csw"])
        + 0.20 * _normalize_0_100(pitchers["opponent_k_rate"])
    ).clip(0, 100)

    pitchers["InningDepthScore"] = (
        0.45 * _normalize_0_100(pitchers["projected_innings"])
        + 0.35 * _normalize_0_100(pitchers["pitch_count_expectation"])
        + 0.20 * _normalize_0_100(pitchers["quality_start_rate"])
    ).clip(0, 100)

    pitchers["MatchupSafetyScore"] = (
        0.30 * _normalize_0_100(pitchers["opponent_woba"], inverse=True)
        + 0.20 * _normalize_0_100(pitchers["opponent_iso"], inverse=True)
        + 0.15 * _normalize_0_100(pitchers["pitcher_bb_rate"], inverse=True)
        + 0.15 * _normalize_0_100(pitchers["park_factor"], inverse=True)
        + 0.20 * _normalize_0_100(pitchers["pitcher_hard_hit_allowed"], inverse=True)
    ).clip(0, 100)

    pitchers["WinEquityScore"] = _normalize_0_100(pitchers["team_win_probability"])

    pitchers["BlowupRiskScore"] = (
        0.35 * _normalize_0_100(pitchers["pitcher_hr9"])
        + 0.25 * _normalize_0_100(pitchers["pitcher_bb_rate"])
        + 0.20 * _normalize_0_100(pitchers["pitcher_hard_hit_allowed"])
        + 0.20 * _normalize_0_100(pitchers["opponent_iso"])
    ).clip(0, 100)

    pitchers["PitcherMedianScore"] = (
        0.30 * pitchers["ProjectionScore"]
        + 0.25 * pitchers["KUpsideScore"]
        + 0.20 * pitchers["InningDepthScore"]
        + 0.15 * pitchers["MatchupSafetyScore"]
        + 0.10 * pitchers["WinEquityScore"]
    ).clip(0, 100)

    pitchers["PitcherCeilingScore"] = (
        0.20 * pitchers["ProjectionScore"]
        + 0.38 * pitchers["KUpsideScore"]
        + 0.18 * pitchers["InningDepthScore"]
        + 0.10 * pitchers["MatchupSafetyScore"]
        + 0.14 * pitchers["WinEquityScore"]
    ).clip(0, 100)

    pitchers["PitcherSafetyScore"] = (
        0.30 * pitchers["MatchupSafetyScore"]
        + 0.25 * pitchers["InningDepthScore"]
        + 0.20 * pitchers["ProjectionScore"]
        + 0.15 * pitchers["WinEquityScore"]
        - 0.10 * pitchers["BlowupRiskScore"]
    ).clip(0, 100)

    projection_per_dollar = pitchers["projection"] / pitchers["salary"].replace(0, pd.NA)
    pitchers["PitcherValueScore"] = (
        0.65 * _normalize_0_100(projection_per_dollar.fillna(0))
        + 0.35 * pitchers["PitcherMedianScore"]
    ).clip(0, 100)

    pitchers["PitcherLeverageScore"] = (
        0.55 * _normalize_0_100(pitchers["PitcherCeilingScore"])
        + 0.10 * _normalize_0_100(pitchers["PitcherSafetyScore"])
        - 0.35 * _normalize_0_100(pitchers["ownership"])
    ).clip(0, 100)

    pitchers["BuildScore_cash"] = (0.60 * pitchers["PitcherSafetyScore"] + 0.40 * pitchers["PitcherMedianScore"]).clip(0, 100)
    pitchers["BuildScore_single_entry"] = (
        0.30 * pitchers["PitcherMedianScore"]
        + 0.35 * pitchers["PitcherCeilingScore"]
        + 0.20 * pitchers["PitcherSafetyScore"]
        + 0.15 * pitchers["PitcherLeverageScore"]
    ).clip(0, 100)
    pitchers["BuildScore_mme"] = (
        0.15 * pitchers["PitcherMedianScore"]
        + 0.40 * pitchers["PitcherCeilingScore"]
        + 0.10 * pitchers["PitcherSafetyScore"]
        + 0.35 * pitchers["PitcherLeverageScore"]
    ).clip(0, 100)

    return pitchers



def score_slate(df: pd.DataFrame) -> Tuple[pd.DataFrame, pd.DataFrame]:
    hitters = _score_hitters(df)
    pitchers = _score_pitchers(df)

    scored = df.copy()
    score_cols = [col for col in hitters.columns if col.endswith("Score") or col.startswith("BuildScore")]
    for column in score_cols:
        scored[column] = 0.0
    scored.loc[hitters.index, hitters.columns.intersection(scored.columns)] = hitters[hitters.columns.intersection(scored.columns)]

    pitcher_score_cols = [col for col in pitchers.columns if col.endswith("Score") or col.startswith("BuildScore")]
    for column in pitcher_score_cols:
        if column not in scored.columns:
            scored[column] = 0.0
    scored.loc[pitchers.index, pitchers.columns.intersection(scored.columns)] = pitchers[pitchers.columns.intersection(scored.columns)]

    stacks = build_team_stack_scores(scored)
    return scored, stacks



def build_team_stack_scores(scored_df: pd.DataFrame) -> pd.DataFrame:
    hitters = scored_df[~scored_df["is_pitcher"]].copy()
    if hitters.empty:
        return pd.DataFrame(columns=["team", "RawStackScore", "CeilingStackScore", "ValueStackScore", "LeverageStackScore", "ChalkRiskScore"])

    rows: List[Dict[str, Any]] = []
    for team, group in hitters.groupby("team"):
        if not team:
            continue
        ordered = group.sort_values(by=["batting_order", "HitterStackScore"], ascending=[True, False]).copy()
        top5 = ordered.head(5)
        avg_top5_ceiling = float(top5["HitterCeilingScore"].mean()) if not top5.empty else 0.0
        avg_top5_hr = float(top5["HRUpsideScore"].mean()) if "HRUpsideScore" in top5.columns and not top5.empty else 0.0
        stack_ppd = ((group["projection"].sum() / max(group["salary"].sum(), 1)) * 1000) if group["salary"].sum() else 0.0
        cheap_top6 = float((ordered.head(6)["salary"] <= ordered["salary"].median()).mean() * 100) if not ordered.empty else 0.0
        order_concentration = float((ordered.head(5)["batting_order"] <= 5).mean() * 100) if not ordered.empty else 0.0
        projected_team_ownership = float(group["ownership"].mean()) if "ownership" in group.columns else 0.0

        rows.append(
            {
                "team": team,
                "team_implied_runs": float(group["team_implied_runs"].max()),
                "avg_top5_hitter_ceiling": avg_top5_ceiling,
                "avg_top5_hr_upside": avg_top5_hr,
                "pitcher_weakness": float(group["PitcherWeaknessScore"].mean()) if "PitcherWeaknessScore" in group.columns else 0.0,
                "bullpen_weakness": float(group["BullpenWeaknessScore"].mean()) if "BullpenWeaknessScore" in group.columns else 0.0,
                "park_factor": float(group["park_factor"].mean()),
                "weather_factor": float(group["weather_factor"].mean()),
                "order_concentration": order_concentration,
                "stack_points_per_dollar": stack_ppd,
                "cheap_top6_hitters_availability": cheap_top6,
                "projected_team_stack_ownership": projected_team_ownership,
            }
        )

    stacks = pd.DataFrame(rows)
    if stacks.empty:
        return stacks

    stacks["TeamRunScore"] = _normalize_0_100(stacks["team_implied_runs"])
    stacks["Top5CeilingScore"] = _normalize_0_100(stacks["avg_top5_hitter_ceiling"])
    stacks["Top5HRScore"] = _normalize_0_100(stacks["avg_top5_hr_upside"])
    stacks["PitcherWeaknessScore"] = _normalize_0_100(stacks["pitcher_weakness"])
    stacks["BullpenWeaknessScore"] = _normalize_0_100(stacks["bullpen_weakness"])
    stacks["ParkScore"] = _normalize_0_100(stacks["park_factor"])
    stacks["WeatherScore"] = _normalize_0_100(stacks["weather_factor"])
    stacks["OrderConcentrationScore"] = _normalize_0_100(stacks["order_concentration"])
    stacks["StackPPDScore"] = _normalize_0_100(stacks["stack_points_per_dollar"])
    stacks["CheapTop6Score"] = _normalize_0_100(stacks["cheap_top6_hitters_availability"])
    stacks["ChalkRiskScore"] = _normalize_0_100(stacks["projected_team_stack_ownership"])

    stacks["RawStackScore"] = (
        0.28 * stacks["TeamRunScore"]
        + 0.18 * stacks["Top5CeilingScore"]
        + 0.15 * stacks["PitcherWeaknessScore"]
        + 0.12 * stacks["BullpenWeaknessScore"]
        + 0.10 * stacks["ParkScore"]
        + 0.07 * stacks["WeatherScore"]
        + 0.10 * stacks["OrderConcentrationScore"]
    ).clip(0, 100)

    stacks["CeilingStackScore"] = (
        0.24 * stacks["TeamRunScore"]
        + 0.22 * stacks["Top5HRScore"]
        + 0.18 * stacks["PitcherWeaknessScore"]
        + 0.12 * stacks["BullpenWeaknessScore"]
        + 0.12 * stacks["ParkScore"]
        + 0.12 * stacks["WeatherScore"]
    ).clip(0, 100)

    stacks["ValueStackScore"] = (
        0.45 * stacks["StackPPDScore"]
        + 0.35 * stacks["RawStackScore"]
        + 0.20 * stacks["CheapTop6Score"]
    ).clip(0, 100)

    stacks["LeverageStackScore"] = (
        0.55 * stacks["CeilingStackScore"]
        + 0.20 * stacks["RawStackScore"]
        - 0.25 * stacks["ChalkRiskScore"]
    ).clip(0, 100)

    return stacks.sort_values(by=["LeverageStackScore", "RawStackScore"], ascending=[False, False]).reset_index(drop=True)


